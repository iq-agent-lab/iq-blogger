# =============================================================================
# iq-blogger — .gitignore
# =============================================================================

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# ── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development

# ── iq-blogger working directories ───────────────────────────────────────────
# 변환 결과물 (개인 작업 공간, blog 레포에 PR로 보낼 때까지 로컬에만)
drafts/

# 입력 캐시 (다른 레포에서 복사해온 deep-dive 원본)
test-inputs/
.cache/

# 진행 추적 파일 (drafts/ 안에 있어서 자동 무시되지만 명시)
progress.json

# ── IDE / Editor ─────────────────────────────────────────────────────────────
# JetBrains (IntelliJ, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# VSCode
.vscode/
*.code-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ── OS ───────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── TypeScript / Vitest cache ────────────────────────────────────────────────
.tscache/
coverage/
.vitest/

test-inputs/redis-deep-dive/
